model Project {
  id     String @id @default(uuid())
  title  String
  userId String
  // sandboxExId String? @unique hidden for now
  user   User   @relation(fields: [userId], references: [id])

  sessions Session[]
  rootNode Node?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([userId])
}
