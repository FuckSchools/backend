model Message {
  id       String      @id @default(uuid())
  threadId String
  thread   Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  content  String
  role     MessageRole

  createdAt DateTime @default(now())

  @@index([threadId, role])
}

enum MessageRole {
  SYSTEM
  HUMAN
  TOOL
  AI
}
